{
	"compilerOptions": {
		"target": "esnext",
		"module": "esnext",
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"allowJs": false,
		"checkJs": false,
		"noEmit": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noImplicitReturns": true,
		"noFallthroughCasesInSwitch": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"jsx": "react-jsx",
		"jsxImportSource": "@bedrock-core/ui",
		"paths": {
			"@bedrock-core/ui": [
				"./packages/ui-runtime/src/index.ts"
			],
			"@bedrock-core/ui/*": [
				"./packages/ui-runtime/src/*"
			],
			"@bedrock-core/ui/jsx-runtime": [
				"./packages/ui-runtime/src/jsx/jsx-runtime.ts"
			],
			"@bedrock-core/ui/jsx-dev-runtime": [
				"./packages/ui-runtime/src/jsx/jsx-dev-runtime.ts"
			],
			"@bedrock-core/ui-runtime": [
				"./packages/ui-runtime/src/index.ts"
			],
			"@bedrock-core/ui-runtime/*": [
				"./packages/ui-runtime/src/*"
			],
			"@bedrock-core/navigation": [
				"./packages/navigation/src/index.ts"
			],
			"@bedrock-core/navigation/*": [
				"./packages/navigation/src/*"
			],
			"@bedrock-core/ore-styled": [
				"./packages/ore-styled/src/index.ts"
			],
			"@bedrock-core/ore-styled/*": [
				"./packages/ore-styled/src/*"
			]
		}
	},
	"exclude": [
		"node_modules",
		"**/node_modules",
		"packages/cli/templates"
	]
}
