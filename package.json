{
  "name": "@bedrock-core/ui",
  "version": "0.5.3",
  "description": "Customizable UI system for Minecraft Bedrock Server server forms cross-addon compatible.",
  "keywords": [
    "ui",
    "api",
    "minecraft",
    "bedrock",
    "typescript",
    "framework"
  ],
  "license": "MIT",
  "author": "DrAv0011",
  "contributors": [
    {
      "name": "DrAv0011",
      "email": "contact@drav.dev",
      "url": "https://drav.dev"
    }
  ],
  "repository": "github:bedrock-core/ui",
  "type": "module",
  "bin": "./packages/cli/dist/index.js",
  "exports": {
    ".": {
      "types": "./packages/ui-runtime/src/index.ts",
      "import": "./packages/ui-runtime/src/index.ts"
    },
    "./navigation": {
      "types": "./packages/navigation/src/index.ts",
      "import": "./packages/navigation/src/index.ts"
    },
    "./flexbox": {
      "types": "./packages/flexbox/src/index.ts",
      "import": "./packages/flexbox/src/index.ts"
    },
    "./jsx-runtime": {
      "types": "./packages/ui-runtime/src/jsx/jsx-runtime.ts",
      "import": "./packages/ui-runtime/src/jsx/jsx-runtime.ts"
    },
    "./jsx-dev-runtime": {
      "types": "./packages/ui-runtime/src/jsx/jsx-dev-runtime.ts",
      "import": "./packages/ui-runtime/src/jsx/jsx-dev-runtime.ts"
    }
  },
  "files": [
    "packages/ui-runtime/src",
    "packages/navigation/src",
    "packages/flexbox/src",
    "packages/cli/dist",
    "packages/cli/templates",
    "README.md",
    "LICENSE"
  ],
  "packageManager": "yarn@4.14.1",
  "workspaces": [
    "packages/ui-runtime",
    "packages/navigation",
    "packages/ore-styled",
    "packages/resource-pack",
    "packages/cli",
    "packages/flexbox"
  ],
  "scripts": {
    "regolith-install": "yarn workspaces foreach -i -A --topological --jobs=1 run regolith-install",
    "build": "yarn workspaces foreach -ptA run build",
    "prepack": "yarn build",
    "watch": "concurrently \"nodemon\"",
    "lint": "yarn workspaces foreach -ptA run lint",
    "test": "yarn workspaces foreach -ptA run test",
    "coverage": "yarn workspaces foreach -ptA run coverage"
  },
  "dependencies": {
    "@bedrock-core/flexbox": "^0.5.3",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "fs-extra": "^11.3.5",
    "ora": "^9.4.0",
    "prompts": "^2.4.2",
    "validate-npm-package-name": "^7.0.2"
  },
  "devDependencies": {
    "@eslint/css": "^1.2.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
    "@eslint/markdown": "^8.0.1",
    "@minecraft/server": "^2.7.0",
    "@minecraft/server-ui": "^2.0.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@vitest/coverage-v8": "^4.1.5",
    "concurrently": "^9.2.1",
    "eslint": "^10.3.0",
    "nodemon": "^3.1.14",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "@minecraft/server": "*",
    "@minecraft/server-ui": "*"
  },
  "resolutions": {
    "@minecraft/server": "2.7.0",
    "@minecraft/server-ui": "2.0.0"
  }
}
