{
  "name": "@bedrock-core/ui",
  "version": "0.6.0",
  "description": "Customizable UI system for Minecraft Bedrock server forms cross-addon compatible.",
  "keywords": [
    "ui",
    "api",
    "minecraft",
    "bedrock",
    "typescript",
    "framework"
  ],
  "license": "MIT",
  "author": "DrAv0011",
  "contributors": [
    {
      "name": "DrAv0011",
      "email": "contact@drav.dev",
      "url": "https://drav.dev"
    }
  ],
  "repository": "github:bedrock-core/ui",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./navigation": {
      "types": "./src/navigation.ts",
      "import": "./src/navigation.ts"
    },
    "./ore-styled": {
      "types": "./src/ore-styled.ts",
      "import": "./src/ore-styled.ts"
    },
    "./flexbox": {
      "types": "./src/flexbox.ts",
      "import": "./src/flexbox.ts"
    },
    "./jsx-runtime": {
      "types": "./src/jsx/jsx-runtime.ts",
      "import": "./src/jsx/jsx-runtime.ts"
    },
    "./jsx-dev-runtime": {
      "types": "./src/jsx/jsx-dev-runtime.ts",
      "import": "./src/jsx/jsx-dev-runtime.ts"
    }
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "packageManager": "yarn@4.14.1",
  "workspaces": [
    "packages/ui-runtime",
    "packages/navigation",
    "packages/ore-styled",
    "packages/resource-pack",
    "packages/cli",
    "packages/flexbox"
  ],
  "scripts": {
    "regolith-install": "yarn workspaces foreach -i -A --topological --jobs=1 run regolith-install",
    "build": "yarn workspaces foreach -ptA run build",
    "prepack": "yarn build",
    "watch": "concurrently \"nodemon\"",
    "lint": "yarn workspaces foreach -ptA run lint",
    "test": "yarn workspaces foreach -ptA run test",
    "coverage": "yarn workspaces foreach -ptA run coverage"
  },
  "dependencies": {
    "@bedrock-core/flexbox": "^0.6.0",
    "@bedrock-core/navigation": "^0.6.0",
    "@bedrock-core/ore-styled": "^0.6.0",
    "@bedrock-core/ui-runtime": "^0.6.0"
  },
  "devDependencies": {
    "@eslint/css": "^1.2.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
    "@eslint/markdown": "^8.0.1",
    "@minecraft/server": "^2.7.0",
    "@minecraft/server-ui": "^2.0.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@vitest/coverage-v8": "^4.1.5",
    "concurrently": "^9.2.1",
    "eslint": "^10.3.0",
    "nodemon": "^3.1.14",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "@minecraft/server": "*",
    "@minecraft/server-ui": "*"
  },
  "resolutions": {
    "@minecraft/server": "2.7.0",
    "@minecraft/server-ui": "2.0.0"
  }
}
