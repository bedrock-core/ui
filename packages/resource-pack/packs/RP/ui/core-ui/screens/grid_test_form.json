{
	"namespace": "grid_test",
	"grid_test_panel": {
		"type": "panel",
		"size": [
			"100%",
			"100%"
		],
		"controls": [
			{
				"grid@grid_test.grid_items": {}
			}
		]
	},
	"grid_items": {
		"type": "grid",
		"size": [
			"328px",
			"98%"
		],
		"grid_dimensions": [
			9,
			200
		],
		"grid_item_template": "grid_test.grid_item_panel",
		"collection_name": "form_buttons"
	},
	"grid_item_panel": {
		"type": "panel",
		"size": [
			18,
			18
		],
		"controls": [
			{
				"bg": {
					"type": "image",
					"size": [ 18, 18 ],
					"texture": "textures/ui/cell_image"
				}
			},
			{
				"item_slot@grid_test.item_button": {}
			}
		]
	},
	"item_button@common.button": {
		"$pressed_button_name": "button.form_button_click",
		"$aux_id": [
			{
				"binding_name": "#form_button_texture",
				"binding_type": "collection",
				"binding_collection_name": "form_buttons"
			},
			{
				"binding_type": "view",
				"source_property_name": "((#form_button_texture - (#form_button_texture % 65536)) / 65536)",
				"target_property_name": "#item_id_aux"
			}
		],
		"bindings": [
			{
				"binding_name": "#null",
				"binding_type": "collection",
				"binding_condition": "none",
				"binding_collection_name": "form_buttons"
			},
			{
				"binding_name": "#null",
				"binding_type": "collection_details",
				"binding_collection_name": "form_buttons"
			}
		],
		"default_control": "default",
		"hover_control": "hover",
		"pressed_control": "pressed",
		"controls": [
			{
				"default@grid_test.item_render_panel": {}
			},
			{
				"hover@grid_test.item_render_panel": {}
			},
			{
				"pressed@grid_test.item_render_panel": {}
			}
		]
	},
	"item_render_panel": {
		"type": "panel",
		"size": [
			14,
			14
		],
		"controls": [
			{
				"item@beacon.item_renderer": {
					"size": [
						14,
						14
					],
					"bindings": "$aux_id"
				}
			}
		]
	}
}