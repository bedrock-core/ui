{
	// ─────────────────────────────────────────────────────────────────────────────
	// MAIN scroll (the base) — the proven single-scroll layout, fixed size.
	//
	// This is the original working `scroll_screen` structure. The ONLY change for the
	// v0007 scroll-list title is WHERE the content height is read: the title is now
	//   header(9) + s:'scrolls'(83) + scroll0[ axis, x, y, width, height, extent ] (6×83)
	// so the root scroll's content height is the `extent` field of block 0 → at byte
	// offset 83·6 = 498 after the header (skip type + axis,x,y,width,height).
	//
	// Width is baked (the main scroll always fills the centered content area); only the
	// scroll height (content extent) is data-driven, exactly like before. The extra
	// positioned scrolls are a SEPARATE control added on top once this base is verified.
	// ─────────────────────────────────────────────────────────────────────────────
	"namespace": "core_ui_screens",
	"scroll": {
		"type": "scroll_view",
		"size": [
			"328px",
			"95%"
		],
		"offset": [
			0,
			"1%"
		],
		"anchor_from": "top_left",
		"anchor_to": "top_left",
		/* Root scroll (index 0): present ONLY in single-scroll mode (no custom <Scroll>s).
		   When pool mode is active (≥1 custom scroll → block 1 present → #axis1 not empty),
		   this scroll_view is hidden; the scroll_pool's pool_content takes over region-0 rendering
		   at full 328px × 100% size with no offset, matching the pool's coordinate space. */
		"visible": "#not_pool_mode",
		"property_bag": {
			"#axis1": ""
		},
		"bindings": [
			{
				"binding_name": "#title_text"
			},
			{
				"binding_type": "view",
				"source_property_name": "('%.9s' * #title_text)",
				"target_property_name": "#protocol_header"
			},
			{
				"binding_type": "view",
				"source_property_name": "(#title_text - #protocol_header)",
				"target_property_name": "#rem_after_header"
			},
			{
				/* block 1 axis at offset 581 — present when there are ≥1 custom scrolls */
				"binding_type": "view",
				"source_property_name": "('%.581s' * #rem_after_header)",
				"target_property_name": "#pre_axis1"
			},
			{
				"binding_type": "view",
				"source_property_name": "(#rem_after_header - #pre_axis1)",
				"target_property_name": "#at_axis1"
			},
			{
				"binding_type": "view",
				"source_property_name": "('%.83s' * #at_axis1)",
				"target_property_name": "#raw_axis1"
			},
			{
				"binding_type": "view",
				"source_property_name": "(('%.82s' * #raw_axis1) - ('%.2s' * #raw_axis1) - ';')",
				"target_property_name": "#axis1"
			},
			{
				/* hidden in pool mode (axis1 not empty = custom scrolls present) */
				"binding_type": "view",
				"source_property_name": "(#axis1 = '')",
				"target_property_name": "#not_pool_mode"
			}
		],
		"scroll_speed": 15,
		"scrollbar_track_button": "button.scrollbar_skip_track",
		"scrollbar_touch_button": "button.scrollbar_touch",
		"always_listen_to_input": true,
		"always_handle_pointer": true,
		"always_handle_scrolling": true,
		"scroll_content": "scrolling_content",
		"scroll_view_port": "scrolling_view_port",
		"scrollbar_track": "track",
		"scrollbar_box": "box",
		"scroll_box_and_track_panel": "bar_and_track",
		"button_mappings": [
			{
				"from_button_id": "button.menu_select",
				"to_button_id": "button.scrollbar_touch",
				"mapping_type": "pressed",
				"button_up_right_of_first_refusal": true
			}
		],
		"controls": [
			{
				"scrolling_view_port": {
					"type": "panel",
					"size": [
						"100%",
						"100%"
					],
					"anchor_from": "top_left",
					"anchor_to": "top_left",
					"clips_children": true,
					"controls": [
						{
							"size_anchor": {
								"type": "panel",
								"size": [
									1,
									1
								],
								"anchor_from": "top_left",
								"anchor_to": "top_left",
								"controls": [
									{
										"scrolling_content@core_ui_screens.scroll_content": {
											"anchor_from": "top_left",
											"anchor_to": "top_left"
										}
									}
								]
							}
						}
					]
				}
			},
			{
				"bar_and_track@core_ui_screens.scrollbar": {}
			}
		]
	},
	"scroll_content": {
		"type": "panel",
		"size": [
			"328px",
			0
		],
		"anchor_from": "top_left",
		"anchor_to": "top_left",
		/* Gate the region-0 content on THIS inner panel — the verified analog of
		   scroll_pool.pool_content. A plain panel directly wrapping the collection honors visible
		   and propagates it to the collection (proven: scroll_pool→pool_content→collection hides
		   in single mode). Gating ABOVE the scroll_view (its own visible, or a wrapper panel) does
		   NOT reach the collection — the scroll_view renders its content regardless (binary search
		   confirmed scroll_root as the duplicate source). #title_text is already proven to evaluate
		   here (the extent binding below reads it). Hidden in pool mode → pool_content owns region 0. */
		"visible": "#visible",
		"property_bag": {
			"#size_binding_y": 0.0,
			"#axis1": "",
			"#visible": true
		},
		"bindings": [
			{
				"binding_name": "#title_text"
			},
			{
				"binding_type": "view",
				"source_property_name": "('%.9s' * #title_text)",
				"target_property_name": "#protocol_header"
			},
			{
				"binding_type": "view",
				"source_property_name": "(#title_text - #protocol_header)",
				"target_property_name": "#rem_after_header"
			},
			{
				"binding_type": "view",
				"source_property_name": "('%.498s' * #rem_after_header)",
				"target_property_name": "#pre_extent"
			},
			{
				"binding_type": "view",
				"source_property_name": "(#rem_after_header - #pre_extent)",
				"target_property_name": "#at_extent"
			},
			{
				"binding_type": "view",
				"source_property_name": "('%.83s' * #at_extent)",
				"target_property_name": "#raw_extent"
			},
			{
				"binding_type": "view",
				"source_property_name": "((('%.82s' * #raw_extent) - ('%.2s' * #raw_extent) - ';') * 1)",
				"target_property_name": "#size_binding_y"
			},
			{
				/* block 1 axis @ 581 — present when there are ≥1 custom scrolls (pool mode) */
				"binding_type": "view",
				"source_property_name": "('%.581s' * #rem_after_header)",
				"target_property_name": "#pre_axis1"
			},
			{
				"binding_type": "view",
				"source_property_name": "(#rem_after_header - #pre_axis1)",
				"target_property_name": "#at_axis1"
			},
			{
				"binding_type": "view",
				"source_property_name": "('%.83s' * #at_axis1)",
				"target_property_name": "#raw_axis1"
			},
			{
				"binding_type": "view",
				"source_property_name": "(('%.82s' * #raw_axis1) - ('%.2s' * #raw_axis1) - ';')",
				"target_property_name": "#axis1"
			},
			{
				/* single mode → visible; pool mode (axis1 not empty) → hidden. Uses the
				   conventional #visible property name that every component binds its visibility to. */
				"binding_type": "view",
				"source_property_name": "(#axis1 = '')",
				"target_property_name": "#visible"
			}
		],
		"controls": [
			{
				/* DEBUG: prints the decoded axis1 (mode flag) at the top of the region-0 content.
				   Shows only while scroll_content is visible — if you see the duplicated header but
				   NOT this label, the collection is rendering despite its parent being hidden. */
				"debug_axis_label": {
					"type": "label",
					"size": [
						"100%",
						"default"
					],
					"offset": [
						0,
						0
					],
					"anchor_from": "top_left",
					"anchor_to": "top_left",
					"layer": 100,
					"color": [
						1,
						0,
						0
					],
					"text": "#dbg_text",
					"property_bag": {
						"#axis1": "",
						"#dbg_text": ""
					},
					"bindings": [
						{
							"binding_name": "#title_text"
						},
						{
							"binding_type": "view",
							"source_property_name": "('%.9s' * #title_text)",
							"target_property_name": "#protocol_header"
						},
						{
							"binding_type": "view",
							"source_property_name": "(#title_text - #protocol_header)",
							"target_property_name": "#rem_after_header"
						},
						{
							"binding_type": "view",
							"source_property_name": "('%.581s' * #rem_after_header)",
							"target_property_name": "#pre_axis1"
						},
						{
							"binding_type": "view",
							"source_property_name": "(#rem_after_header - #pre_axis1)",
							"target_property_name": "#at_axis1"
						},
						{
							"binding_type": "view",
							"source_property_name": "('%.83s' * #at_axis1)",
							"target_property_name": "#raw_axis1"
						},
						{
							"binding_type": "view",
							"source_property_name": "(('%.82s' * #raw_axis1) - ('%.2s' * #raw_axis1) - ';')",
							"target_property_name": "#axis1"
						},
						{
							/* mirror the gate: single mode → 'VIS1' (panel shown), pool mode → 'VIS0' (should hide) */
							"binding_type": "view",
							"source_property_name": "(((#axis1 = '') and 'VIS1') or 'VIS0')",
							"target_property_name": "#vis_str"
						},
						{
							"binding_type": "view",
							"source_property_name": "('AX1=[' + #axis1 + '] ' + #vis_str)",
							"target_property_name": "#dbg_text"
						}
					]
				}
			},
			{
				"buttons_collection": {
					"type": "collection_panel",
					"size": [
						"100%",
						"100%"
					],
					"offset": [
						"-50%",
						"-50%"
					],
					"anchor_from": "top_left",
					"anchor_to": "top_left",
					"factory": {
						"name": "buttons",
						"control_ids": {
							"button": "@core_ui_common.button_router",
							"label": "@core_ui_common.label_router",
							"header": "@core_ui_common.unused",
							"divider": "@core_ui_common.unused"
						}
					},
					"collection_name": "form_buttons",
					"bindings": [
						{
							"binding_name": "#form_button_contents",
							"binding_name_override": "#collection_length"
						}
					]
				}
			}
		]
	},
	"scrollbar": {
		"type": "panel",
		"size": [
			"6px",
			"100%"
		],
		"anchor_from": "right_middle",
		"anchor_to": "right_middle",
		"controls": [
			{
				"track": {
					"type": "scroll_track",
					"size": [
						"6px",
						"100%"
					],
					"anchor_from": "center",
					"anchor_to": "center",
					"button_mappings": [
						{
							"from_button_id": "button.menu_select",
							"to_button_id": "button.scrollbar_skip_track",
							"mapping_type": "pressed"
						}
					],
					"controls": [
						{
							"bar_indent@common.scroll_indent_image": {
								"anchor_from": "center",
								"anchor_to": "center"
							}
						}
					]
				}
			},
			{
				"box": {
					"type": "scrollbar_box",
					"size": [
						"6px",
						"20%"
					],
					"anchor_from": "top_middle",
					"anchor_to": "top_middle",
					"draggable": "vertical",
					"contained": true,
					"button_mappings": [
						{
							"from_button_id": "button.menu_select",
							"to_button_id": "button.menu_select",
							"mapping_type": "pressed",
							"button_up_right_of_first_refusal": true
						}
					],
					"controls": [
						{
							"handle@common.scrollbar_box_image": {
								"anchor_from": "center",
								"anchor_to": "center"
							}
						}
					]
				}
			}
		]
	}
}
