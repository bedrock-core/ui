{
	"namespace": "core_ui_screens",

	// Two independent vertical scroll regions side by side. Both bind the SAME
	// `form_buttons` collection; each region's content selects region-specific routers
	// (region 0 = base routers, region 1 = *_r1 routers passing $region_filter: 1) so each
	// column only shows its own elements.
	//
	// Asymmetric 34% / 66% columns: left 109px, right 211px, summing to the 320px container
	// (centered by screen_container's "50% - 50%c" offset). The two columns are flush (no gap
	// — authors add padding). The scroll_view VIEWPORT widths are baked here (109 / 211) and
	// must match DUAL_SCROLL_LEFT_WIDTH / DUAL_SCROLL_RIGHT_WIDTH in ui-runtime; the CONTENT
	// width is data-driven from the title (via the [1,1] size_anchor #size_binding_x trick).
	//
	// Title field layout (each field 83 bytes, after the 9-byte header):
	//   [0] screen type  [1] height0  [2] width0  [3] height1  [4] width1
	// skips: height0 -> 83, width0 -> 166, height1 -> 249, width1 -> 332.

	"dual_scroll": {
		"type": "panel",
		"size": [
			"320px",
			"100%"
		],
		"anchor_from": "top_left",
		"anchor_to": "top_left",
		"controls": [
			{
				"left_scroll@core_ui_screens.dual_left_scroll": {}
			},
			{
				"right_scroll@core_ui_screens.dual_right_scroll": {}
			}
		]
	},

	// Shared scrollbar (track + thumb), referenced by name from each scroll_view.
	"dual_scrollbar": {
		"type": "panel",
		"size": [
			"6px",
			"100%"
		],
		"anchor_from": "right_middle",
		"anchor_to": "right_middle",
		"controls": [
			{
				"track": {
					"type": "scroll_track",
					"size": [
						"6px",
						"100%"
					],
					"anchor_from": "center",
					"anchor_to": "center",
					"button_mappings": [
						{
							"from_button_id": "button.menu_select",
							"to_button_id": "button.scrollbar_skip_track",
							"mapping_type": "pressed"
						}
					],
					"controls": [
						{
							"bar_indent@common.scroll_indent_image": {
								"anchor_from": "center",
								"anchor_to": "center"
							}
						}
					]
				}
			},
			{
				"box": {
					"type": "scrollbar_box",
					"size": [
						"6px",
						"20%"
					],
					"anchor_from": "top_middle",
					"anchor_to": "top_middle",
					"draggable": "vertical",
					"contained": true,
					"button_mappings": [
						{
							"from_button_id": "button.menu_select",
							"to_button_id": "button.menu_select",
							"mapping_type": "pressed",
							"button_up_right_of_first_refusal": true
						}
					],
					"controls": [
						{
							"handle@common.scrollbar_box_image": {
								"anchor_from": "center",
								"anchor_to": "center"
							}
						}
					]
				}
			}
		]
	},

	// ── Left region (region 0) ──────────────────────────────────────────────────────
	"dual_left_scroll": {
		"type": "scroll_view",
		// 34% column — baked viewport width; must match DUAL_SCROLL_LEFT_WIDTH in ui-runtime.
		"size": [
			"109px",
			"95%"
		],
		"offset": [
			0,
			"1%"
		],
		"anchor_from": "top_left",
		"anchor_to": "top_left",
		"scroll_speed": 15,
		"scrollbar_track_button": "button.scrollbar_skip_track",
		"scrollbar_touch_button": "button.scrollbar_touch",
		"always_listen_to_input": true,
		"always_handle_pointer": true,
		// false (vanilla scroll_view_control default) so each region only handles the mouse
		// wheel while hovered (otherwise both greedily capture it and only one responds).
		"always_handle_scrolling": false,
		"scroll_content": "scrolling_content",
		"scroll_view_port": "scrolling_view_port",
		"scrollbar_track": "track",
		"scrollbar_box": "box",
		"scroll_box_and_track_panel": "bar_and_track",
		"button_mappings": [
			{
				"from_button_id": "button.menu_select",
				"to_button_id": "button.scrollbar_touch",
				"mapping_type": "pressed",
				"button_up_right_of_first_refusal": true
			}
		],
		"controls": [
			{
				"scrolling_view_port": {
					"type": "panel",
					"size": [
						"100%",
						"100%"
					],
					"anchor_from": "top_left",
					"anchor_to": "top_left",
					"clips_children": true,
					"controls": [
						{
							"size_anchor": {
								"type": "panel",
								"size": [
									1,
									1
								],
								"anchor_from": "top_left",
								"anchor_to": "top_left",
								"controls": [
									{
										"scrolling_content@core_ui_screens.dual_left_content": {
											"anchor_from": "top_left",
											"anchor_to": "top_left"
										}
									}
								]
							}
						}
					]
				}
			},
			{
				"bar_and_track@core_ui_screens.dual_scrollbar": {}
			}
		]
	},

	// ── Right region (region 1) ─────────────────────────────────────────────────────
	"dual_right_scroll": {
		"type": "scroll_view",
		// 66% column — baked viewport width; must match DUAL_SCROLL_RIGHT_WIDTH in ui-runtime.
		"size": [
			"211px",
			"95%"
		],
		"offset": [
			0,
			"1%"
		],
		"anchor_from": "top_right",
		"anchor_to": "top_right",
		"scroll_speed": 15,
		"scrollbar_track_button": "button.scrollbar_skip_track",
		"scrollbar_touch_button": "button.scrollbar_touch",
		"always_listen_to_input": true,
		"always_handle_pointer": true,
		"always_handle_scrolling": false,
		"scroll_content": "scrolling_content",
		"scroll_view_port": "scrolling_view_port",
		"scrollbar_track": "track",
		"scrollbar_box": "box",
		"scroll_box_and_track_panel": "bar_and_track",
		"button_mappings": [
			{
				"from_button_id": "button.menu_select",
				"to_button_id": "button.scrollbar_touch",
				"mapping_type": "pressed",
				"button_up_right_of_first_refusal": true
			}
		],
		"controls": [
			{
				"scrolling_view_port": {
					"type": "panel",
					"size": [
						"100%",
						"100%"
					],
					"anchor_from": "top_left",
					"anchor_to": "top_left",
					"clips_children": true,
					"controls": [
						{
							"size_anchor": {
								"type": "panel",
								"size": [
									1,
									1
								],
								"anchor_from": "top_left",
								"anchor_to": "top_left",
								"controls": [
									{
										"scrolling_content@core_ui_screens.dual_right_content": {
											"anchor_from": "top_left",
											"anchor_to": "top_left"
										}
									}
								]
							}
						}
					]
				}
			},
			{
				"bar_and_track@core_ui_screens.dual_scrollbar": {}
			}
		]
	},

	// ── Left content (region 0): height0 @ skip 83, width0 @ skip 166, base routers ───
	// Width is data-driven via #size_binding_x exactly like #size_binding_y: this panel sits
	// inside the [1,1] size_anchor, so both bindings map 1:1 to pixels (it overflows the
	// anchor and the scroll_view scrolls it). The viewport/container widths are baked (160 /
	// 320) and match the encoded width.
	"dual_left_content": {
		"type": "panel",
		"size": [
			0,
			0
		],
		"anchor_from": "top_left",
		"anchor_to": "top_left",
		"property_bag": {
			"#size_binding_x": 0.0,
			"#size_binding_y": 0.0
		},
		"bindings": [
			{
				"binding_name": "#title_text"
			},
			{
				"binding_type": "view",
				"source_property_name": "('%.9s' * #title_text)",
				"target_property_name": "#protocol_header"
			},
			{
				"binding_type": "view",
				"source_property_name": "(#title_text - #protocol_header)",
				"target_property_name": "#rem_after_header"
			},
			{
				/* height0 @ skip 83 (after the screen-type field) */
				"binding_type": "view",
				"source_property_name": "('%.83s' * #rem_after_header)",
				"target_property_name": "#pre_h0"
			},
			{
				"binding_type": "view",
				"source_property_name": "(#rem_after_header - #pre_h0)",
				"target_property_name": "#at_h0"
			},
			{
				"binding_type": "view",
				"source_property_name": "('%.83s' * #at_h0)",
				"target_property_name": "#raw_height"
			},
			{
				"binding_type": "view",
				"source_property_name": "((('%.82s' * #raw_height) - ('%.2s' * #raw_height) - ';') * 1)",
				"target_property_name": "#size_binding_y"
			},
			{
				/* width0 @ skip 166 (screen type + height0) */
				"binding_type": "view",
				"source_property_name": "('%.166s' * #rem_after_header)",
				"target_property_name": "#pre_w0"
			},
			{
				"binding_type": "view",
				"source_property_name": "(#rem_after_header - #pre_w0)",
				"target_property_name": "#at_w0"
			},
			{
				"binding_type": "view",
				"source_property_name": "('%.83s' * #at_w0)",
				"target_property_name": "#raw_width"
			},
			{
				"binding_type": "view",
				"source_property_name": "((('%.82s' * #raw_width) - ('%.2s' * #raw_width) - ';') * 1)",
				"target_property_name": "#size_binding_x"
			}
		],
		"controls": [
			{
				"buttons_collection": {
					"type": "collection_panel",
					"size": [
						"100%",
						"100%"
					],
					"offset": [
						"-50%",
						"-50%"
					],
					"anchor_from": "top_left",
					"anchor_to": "top_left",
					"factory": {
						"name": "buttons",
						"control_ids": {
							"button": "@core_ui_common.button_router",
							"label": "@core_ui_common.label_router",
							"header": "@core_ui_common.unused",
							"divider": "@core_ui_common.unused"
						}
					},
					"collection_name": "form_buttons",
					"bindings": [
						{
							"binding_name": "#form_button_contents",
							"binding_name_override": "#collection_length"
						}
					]
				}
			}
		]
	},

	// ── Right content (region 1): height1 @ skip 249, width1 @ skip 332, *_r1 routers ─
	"dual_right_content": {
		"type": "panel",
		"size": [
			0,
			0
		],
		"anchor_from": "top_left",
		"anchor_to": "top_left",
		"property_bag": {
			"#size_binding_x": 0.0,
			"#size_binding_y": 0.0
		},
		"bindings": [
			{
				"binding_name": "#title_text"
			},
			{
				"binding_type": "view",
				"source_property_name": "('%.9s' * #title_text)",
				"target_property_name": "#protocol_header"
			},
			{
				"binding_type": "view",
				"source_property_name": "(#title_text - #protocol_header)",
				"target_property_name": "#rem_after_header"
			},
			{
				/* height1 @ skip 249 (screen type + height0 + width0) */
				"binding_type": "view",
				"source_property_name": "('%.249s' * #rem_after_header)",
				"target_property_name": "#pre_h1"
			},
			{
				"binding_type": "view",
				"source_property_name": "(#rem_after_header - #pre_h1)",
				"target_property_name": "#at_h1"
			},
			{
				"binding_type": "view",
				"source_property_name": "('%.83s' * #at_h1)",
				"target_property_name": "#raw_height"
			},
			{
				"binding_type": "view",
				"source_property_name": "((('%.82s' * #raw_height) - ('%.2s' * #raw_height) - ';') * 1)",
				"target_property_name": "#size_binding_y"
			},
			{
				/* width1 @ skip 332 (screen type + height0 + width0 + height1) */
				"binding_type": "view",
				"source_property_name": "('%.332s' * #rem_after_header)",
				"target_property_name": "#pre_w1"
			},
			{
				"binding_type": "view",
				"source_property_name": "(#rem_after_header - #pre_w1)",
				"target_property_name": "#at_w1"
			},
			{
				"binding_type": "view",
				"source_property_name": "('%.83s' * #at_w1)",
				"target_property_name": "#raw_width"
			},
			{
				"binding_type": "view",
				"source_property_name": "((('%.82s' * #raw_width) - ('%.2s' * #raw_width) - ';') * 1)",
				"target_property_name": "#size_binding_x"
			}
		],
		"controls": [
			{
				"buttons_collection": {
					"type": "collection_panel",
					"size": [
						"100%",
						"100%"
					],
					"offset": [
						"-50%",
						"-50%"
					],
					"anchor_from": "top_left",
					"anchor_to": "top_left",
					"factory": {
						"name": "buttons",
						"control_ids": {
							"button": "@core_ui_common.button_router_r1",
							"label": "@core_ui_common.label_router_r1",
							"header": "@core_ui_common.unused",
							"divider": "@core_ui_common.unused"
						}
					},
					"collection_name": "form_buttons",
					"bindings": [
						{
							"binding_name": "#form_button_contents",
							"binding_name_override": "#collection_length"
						}
					]
				}
			}
		]
	}
}
