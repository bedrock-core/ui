{
	"namespace": "core_ui_screens",
	// ─── Root ──────────────────────────────────────────────────────────────────
	// Fixed (non-scrolling) layout. Two layers over form_buttons:
	//   Layer 0: item_grid (type: grid bound to form_buttons) — items ONLY render here
	//   Layer 1: content_collection (collection_panel factory) — all non-item controls
	//
	"fixed": {
		"type": "panel",
		"size": [
			"328px",
			"210px"
		],
		"anchor_from": "top_left",
		"anchor_to": "top_left",
		"offset": [
			0,
			"50% - 25%c"
		],
		"controls": [
			{
				// Item layer — fills the fixed root; cells self-position by serialized x/y.
				"item_grid@core_ui_components.item_renderer": {}
			},
			{
				// Control layer — collection_panel with center moved to root top-left
				// via -50%/-50% offset so anchored-offset coordinates start at (0,0) = top-left.
				"content_collection": {
					"type": "collection_panel",
					"size": [
						"100%",
						"100%"
					],
					"offset": [
						"-50%",
						"-50%"
					],
					"anchor_from": "top_left",
					"anchor_to": "top_left",
					"factory": {
						"name": "fixed_content_items",
						"control_ids": {
							"button": "@core_ui_common.button_router",
							"label": "@core_ui_common.label_router",
							"header": "@core_ui_common.unused",
							"divider": "@core_ui_common.unused"
						}
					},
					"collection_name": "form_buttons",
					"bindings": [
						{
							"binding_name": "#form_button_contents",
							"binding_name_override": "#collection_length"
						}
					]
				}
			}
		]
	}
}