{
	// Routes button-type factory entries to the appropriate interactive component.
	// Parallel to label_router which handles label-type entries.
	"namespace": "core_ui_common",
	"button_router": {
		"type": "panel",
		// Components must be inside a panel with size [1,1] so size_binding values map 1:1 to pixels.
		"size": [
			1,
			1
		],
		"controls": [
			{
				"button@core_ui_components.button": {}
			},
			{
				"item_renderer@core_ui_components.item_renderer": {}
			}
		]
	},
	// Region-1 variant: identical to button_router but passes $region_filter: 1 down to each
	// component's @ref (reliable direct-reference variable passing), so region-1 scrolls only
	// show their own elements. Region 0 uses the base button_router (component default 0).
	"button_router_r1": {
		"type": "panel",
		"size": [
			1,
			1
		],
		"controls": [
			{
				"button@core_ui_components.button": {
					"$region_filter": 1
				}
			},
			{
				"item_renderer@core_ui_components.item_renderer": {
					"$region_filter": 1
				}
			}
		]
	}
}