{
	// Two modes, by scroll count:
	//  • 0 nested scrolls → the MAIN scroll (scroll_root) wraps & scrolls everything (region 0).
	//  • ≥1 nested scrolls → the screen is fixed (region-0 content fits) and the POOL of custom
	//    scrolls (scroll_pool, gated on ≥2 scrolls) renders as a sibling over the content area.
	// Both are 328px-wide, centred by the literal 50% - 164px offset.
	"namespace": "core_ui_common",
	"screen_container": {
		"type": "panel",
		"size": [
			"100%",
			"100%"
		],
		"anchor_from": "top_left",
		"anchor_to": "top_left",
		"offset": [
			"50% - 164px",
			"0%"
		],
		"$protocol_header": "bcuiv0007",
		"bindings": [
			{
				"binding_name": "#title_text"
			},
			{
				/* Render only for bcui forms — visible when the title carries the protocol header */
				"binding_type": "view",
				"source_property_name": "(not ((#title_text - $protocol_header) = #title_text))",
				"target_property_name": "#visible"
			}
		],
		"controls": [
			{
				"scroll_root@core_ui_screens.scroll": {}
			},
			{
				"scroll_pool@core_ui_screens.scroll_pool": {}
			}
		]
	},
	"unused": {
		"type": "panel",
		"size": [
			0,
			0
		]
	}
}
