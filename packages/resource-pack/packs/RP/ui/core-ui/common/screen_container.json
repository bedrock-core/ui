{
	"namespace": "core_ui_common",
	"screen_container": {
		"type": "panel",
		"size": [
			"100%",
			"100%"
		],
		"anchor_from": "top_left",
		"anchor_to": "top_left",
		"offset": [
			"50% - 50%c",
			"0%"
		],
		"bindings": [
			{
				"binding_name": "#title_text"
			},
			{
				/* Strip protocol header (9 bytes) */
				"binding_type": "view",
				"source_property_name": "('%.9s' * #title_text)",
				"target_property_name": "#protocol_header_sc"
			},
			{
				"binding_type": "view",
				"source_property_name": "(#title_text - #protocol_header_sc)",
				"target_property_name": "#rem_after_header_sc"
			},
			{
				/* Screen type is the first field after the header (83 bytes): 's:' + value + padding + marker */
				"binding_type": "view",
				"source_property_name": "('%.83s' * #rem_after_header_sc)",
				"target_property_name": "#raw_screen_type"
			},
			{
				/* Extract the value: drop the 's:' prefix and the ';' padding */
				"binding_type": "view",
				"source_property_name": "(('%.82s' * #raw_screen_type) - ('%.2s' * #raw_screen_type) - ';')",
				"target_property_name": "#screen_type"
			},
			{
				"binding_type": "view",
				"source_property_name": "(#screen_type = 'inventory')",
				"target_property_name": "#is_inventory"
			},
			{
				"binding_type": "view",
				"source_property_name": "(#screen_type = 'fixed')",
				"target_property_name": "#is_fixed"
			}
		],
		"controls": [
			{
				/* Scroll form — visible when the screen is neither inventory nor fixed.
				   No protocol guard needed: server_form only shows screen_container for bcui forms. */
				"scroll_root@core_ui_screens.scroll": {
					"bindings": [
						{
							"binding_type": "view",
							"source_control_name": "screen_container",
							"source_property_name": "((not #is_inventory) and (not #is_fixed))",
							"target_property_name": "#visible"
						}
					]
				}
			},
			{
				"core_ui_server_form_grid@grid_test.grid_items": {
					"bindings": [
						{
							"binding_type": "view",
							"source_control_name": "screen_container",
							"source_property_name": "(not #is_inventory)",
							"target_property_name": "#visible"
						}
					]
				}
			},
			{
				"fixed_root@core_ui_screens.fixed": {
					"bindings": [
						{
							"binding_type": "view",
							"source_control_name": "screen_container",
							"source_property_name": "#is_fixed",
							"target_property_name": "#visible"
						}
					]
				}
			},
			{
				"inventory_root@core_ui_screens.inventory": {
					"bindings": [
						{
							"binding_type": "view",
							"source_control_name": "screen_container",
							"source_property_name": "#is_inventory",
							"target_property_name": "#visible"
						}
					]
				}
			}
		]
	},
	"unused": {
		"type": "panel",
		"size": [
			0,
			0
		]
	}
}
