{
	// Mounts the MAIN scroll (index 0, the proven fixed base). The EXTRA positioned scrolls
	// (index 1..N) live INSIDE that main scroll (scroll.scrolling_view_port → size_anchor),
	// so the main scroll_view draws their overflow and their pixel #size_binding/anchored
	// offset map 1:1. Centering is a literal 50% - 164px (half the baked 328px width) so the
	// always-present extras can't perturb it.
	"namespace": "core_ui_common",
	"screen_container": {
		"type": "panel",
		"size": [
			"100%",
			"100%"
		],
		"anchor_from": "top_left",
		"anchor_to": "top_left",
		"offset": [
			"50% - 164px",
			"0%"
		],
		"$protocol_header": "bcuiv0007",
		"bindings": [
			{
				"binding_name": "#title_text"
			},
			{
				/* Render only for bcui forms — visible when the title carries the protocol header */
				"binding_type": "view",
				"source_property_name": "(not ((#title_text - $protocol_header) = #title_text))",
				"target_property_name": "#visible"
			}
		],
		"controls": [
			{
				"scroll_root@core_ui_screens.scroll": {}
			},
			{
				"dual_scroll@core_ui_screens.dual_scroll": {}
			}
		]
	},
	"unused": {
		"type": "panel",
		"size": [
			0,
			0
		]
	}
}
