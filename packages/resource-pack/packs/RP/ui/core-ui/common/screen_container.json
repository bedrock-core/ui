{
	"namespace": "core-ui_common",
	"screen_container": {
		"type": "panel",
		"size": [
			"100%",
			"100%"
		],
		"anchor_from": "top_left",
		"anchor_to": "top_left",
		"offset": [
			"50% - 50%c",
			"0%"
		],
		"bindings": [
			{
				"binding_name": "#title_text"
			}
		],
		"controls": [
			{
				"scrolling_panel@common.scrolling_panel": {
					"layer": 999,
					"anchor_from": "top_left",
					"anchor_to": "top_left",
					"size": [
						"328px",
						"98%"
					],
					"offset": [
						0,
						"1%"
					],
					"$protocol_header": "bcuiv0003",
					"$show_background": false,
					"$scrolling_content": "core-ui_common.form_scrolling_content",
					"bindings": [
						{
							"binding_type": "view",
							"source_control_name": "screen_container",
							"source_property_name": "(not ((#title_text - $protocol_header) = #title_text))",
							"target_property_name": "#visible"
						}
					]
				}
			}
		]
	},
	"form_scrolling_content": {
		"type": "panel",
		"size": [
			"328px",
			"100%c"
		],
		"anchor_from": "top_left",
		"anchor_to": "top_left",
		"controls": [
			{
				"generated_contents": {
					"type": "collection_panel",
					"size": [
						"328px",
						"5000px"
					],
					"offset": [
						"-50%",
						"-50%"
					],
					"anchor_from": "top_left",
					"anchor_to": "top_left",
					"property_bag": {
						"#size_binding_y": 0.0
					},
					"factory": {
						"name": "buttons",
						"control_ids": {
							"button": "@core-ui_components.button",
							"label": "@core-ui_common.component_router",
							"header": "@core-ui_common.unused",
							"divider": "@core-ui_common.unused"
						}
					},
					"collection_name": "form_buttons",
					"bindings": [
						{
							"binding_name": "#form_button_contents",
							"binding_name_override": "#collection_length"
						},
						{
							"binding_name": "#title_text"
						},
						{
							"binding_type": "view",
							"source_property_name": "('%.9s' * #title_text)",
							"target_property_name": "#protocol_header"
						},
						{
							"binding_type": "view",
							"source_property_name": "(#title_text - #protocol_header)",
							"target_property_name": "#rem_after_header"
						},
						{
							"binding_type": "view",
							"source_property_name": "('%.83s' * #rem_after_header)",
							"target_property_name": "#raw_title_height"
						},
						{
							"binding_type": "view",
							"source_property_name": "((('%.82s' * #raw_title_height) - ('%.2s' * #raw_title_height) - ';'))",
							"target_property_name": "#size_binding_y"
						}
					]
				}
			}
		]
	},
	"unused": {
		"type": "panel",
		"size": [
			0,
			0
		]
	}
}