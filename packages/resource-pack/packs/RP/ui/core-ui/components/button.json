{
	"namespace": "core_ui_components",
	"button": {
		"type": "button",
		"size": [
			0,
			0
		],
		"layer": 50,
		"anchor_from": "top_left",
		"anchor_to": "top_left",
		"use_anchored_offset": true,
		"property_bag": {
			"#size_binding_x": 0.0,
			"#size_binding_y": 0.0,
			"#anchored_offset_value_x": 0.0,
			"#anchored_offset_value_y": 0.0,
			"#background": "",
			"#background_hover": "",
			"#background_pressed": "",
			"#background_locked": "",
			"#bg_visible": false
		},
		"visible": "#visible",
		"enabled": "#enabled",
		"$normalize": 1.0,
		"bindings": [
			{
				"binding_type": "collection_details",
				"binding_collection_name": "form_buttons"
			},
			{
				"binding_name": "#form_button_text",
				"binding_type": "collection",
				"binding_collection_name": "form_buttons"
			},
			{
				/* --- strip protocol header (9 chars) --- */
				"binding_type": "view", // protocol header size
				"source_property_name": "('%.9s' * #form_button_text)",
				"target_property_name": "#protocol_header"
			},
			{
				"binding_type": "view",
				"source_property_name": "(#form_button_text - #protocol_header)",
				"target_property_name": "#rem_after_header"
			},
			{
				/* --- type (string) - field 0 --- */
				"binding_type": "view", // full_width
				"source_property_name": "('%.83s' * #rem_after_header)",
				"target_property_name": "#raw_type"
			},
			{
				"binding_type": "view",
				"source_property_name": "(#rem_after_header - #raw_type)",
				"target_property_name": "#rem_after_type"
			},
			{
				"binding_type": "view", // (full_width - marker_width) - prefix_width - padding_char (;)
				"source_property_name": "(('%.82s' * #raw_type) - ('%.2s' * #raw_type) - ';')",
				"target_property_name": "#type"
			},
			{
				/* --- width (int) - field 1 --- */
				"binding_type": "view", // full_width
				"source_property_name": "('%.83s' * #rem_after_type)",
				"target_property_name": "#raw_width"
			},
			{
				"binding_type": "view",
				"source_property_name": "(#rem_after_type - #raw_width)",
				"target_property_name": "#rem_after_width"
			},
			{
				"binding_type": "view", // (full_width - marker_width) - prefix_width - padding_char (;)
				"source_property_name": "(('%.82s' * #raw_width) - ('%.2s' * #raw_width) - ';')",
				"target_property_name": "#size_binding_x"
			},
			{
				/* --- height (int) - field 2 --- */
				"binding_type": "view", // full_width
				"source_property_name": "('%.83s' * #rem_after_width)",
				"target_property_name": "#raw_height"
			},
			{
				"binding_type": "view",
				"source_property_name": "(#rem_after_width - #raw_height)",
				"target_property_name": "#rem_after_height"
			},
			{
				"binding_type": "view", // (full_width - marker_width) - prefix_width - padding_char (;)
				"source_property_name": "(('%.82s' * #raw_height) - ('%.2s' * #raw_height) - ';')",
				"target_property_name": "#size_binding_y"
			},
			{
				/* --- x (int) - field 3 --- */
				"binding_type": "view", // full_width
				"source_property_name": "('%.83s' * #rem_after_height)",
				"target_property_name": "#raw_x"
			},
			{
				"binding_type": "view",
				"source_property_name": "(#rem_after_height - #raw_x)",
				"target_property_name": "#rem_after_x"
			},
			{
				"binding_type": "view", // (full_width - marker_width) - prefix_width - padding_char (;)
				"source_property_name": "((('%.82s' * #raw_x) - ('%.2s' * #raw_x) - ';') * $normalize)",
				"target_property_name": "#anchored_offset_value_x"
			},
			{
				/* --- y (float) - field 4 --- */
				"binding_type": "view", // full_width
				"source_property_name": "('%.83s' * #rem_after_x)",
				"target_property_name": "#raw_y"
			},
			{
				"binding_type": "view",
				"source_property_name": "(#rem_after_x - #raw_y)",
				"target_property_name": "#rem_after_y"
			},
			{
				"binding_type": "view", // (full_width - marker_width) - prefix_width - padding_char (;)
				"source_property_name": "((('%.82s' * #raw_y) - ('%.2s' * #raw_y) - ';') * $normalize)",
				"target_property_name": "#anchored_offset_value_y"
			},
			{
				/* --- visible (boolean) - field 5 --- */
				"binding_type": "view", // full_width
				"source_property_name": "('%.8s' * #rem_after_y)",
				"target_property_name": "#raw_visible"
			},
			{
				"binding_type": "view",
				"source_property_name": "(#rem_after_y - #raw_visible)",
				"target_property_name": "#rem_after_visible"
			},
			{
				"binding_type": "view", // (full_width - marker_width) - prefix_width (s:) - padding_char (;)
				"source_property_name": "(('%.7s' * #raw_visible) - ('%.2s' * #raw_visible) - ';')",
				"target_property_name": "#pre_visible"
			},
			{
				/* --- enabled (boolean) - field 6 --- */
				"binding_type": "view", // full_width
				"source_property_name": "('%.8s' * #rem_after_visible)",
				"target_property_name": "#raw_enabled"
			},
			{
				"binding_type": "view",
				"source_property_name": "(#rem_after_visible - #raw_enabled)",
				"target_property_name": "#rem_after_enabled"
			},
			{
				"binding_type": "view", // (full_width - marker_width) - prefix_width - padding_char (;)
				"source_property_name": "(('%.7s' * #raw_enabled) - ('%.2s' * #raw_enabled) - ';')",
				"target_property_name": "#enabled"
			},
			{
				"binding_type": "view",
				"source_property_name": "(#pre_visible and (#type = 'button'))",
				"target_property_name": "#visible"
			},
			{
				/* --- background (string, 83 bytes) - field 7 [440-522] --- */
				"binding_type": "view",
				"source_property_name": "('%.83s' * #rem_after_enabled)",
				"target_property_name": "#raw_background"
			},
			{
				"binding_type": "view",
				"source_property_name": "(#rem_after_enabled - #raw_background)",
				"target_property_name": "#rem_after_background"
			},
			{
				"binding_type": "view",
				"source_property_name": "(('%.82s' * #raw_background) - ('%.2s' * #raw_background) - ';')",
				"target_property_name": "#background"
			},
			{
				/* --- skip $reserved (501 bytes) - field 8 [523-1023] --- */
				"binding_type": "view",
				"source_property_name": "('%.501s' * #rem_after_background)",
				"target_property_name": "#raw_reserved"
			},
			{
				"binding_type": "view",
				"source_property_name": "(#rem_after_background - #raw_reserved)",
				"target_property_name": "#rem_after_reserved"
			},
			{
				/* --- backgroundHover (string, 83 bytes) - component field 1 [1024-1106] --- */
				"binding_type": "view",
				"source_property_name": "('%.83s' * #rem_after_reserved)",
				"target_property_name": "#raw_bg_hover"
			},
			{
				"binding_type": "view",
				"source_property_name": "(#rem_after_reserved - #raw_bg_hover)",
				"target_property_name": "#rem_after_bg_hover"
			},
			{
				"binding_type": "view",
				"source_property_name": "(('%.82s' * #raw_bg_hover) - ('%.2s' * #raw_bg_hover) - ';')",
				"target_property_name": "#background_hover"
			},
			{
				/* --- backgroundPressed (string, 83 bytes) - component field 2 [1107-1189] --- */
				"binding_type": "view",
				"source_property_name": "('%.83s' * #rem_after_bg_hover)",
				"target_property_name": "#raw_bg_pressed"
			},
			{
				"binding_type": "view",
				"source_property_name": "(#rem_after_bg_hover - #raw_bg_pressed)",
				"target_property_name": "#rem_after_bg_pressed"
			},
			{
				"binding_type": "view",
				"source_property_name": "(('%.82s' * #raw_bg_pressed) - ('%.2s' * #raw_bg_pressed) - ';')",
				"target_property_name": "#background_pressed"
			},
			{
				/* --- backgroundLocked (string, 83 bytes) - component field 3 [1190-1272] --- */
				"binding_type": "view",
				"source_property_name": "('%.83s' * #rem_after_bg_pressed)",
				"target_property_name": "#raw_bg_locked"
			},
			{
				"binding_type": "view",
				"source_property_name": "(('%.82s' * #raw_bg_locked) - ('%.2s' * #raw_bg_locked) - ';')",
				"target_property_name": "#background_locked"
			},
			{
				"binding_type": "view",
				"source_property_name": "(not (#background = ''))",
				"target_property_name": "#bg_visible"
			}
		],
		// === Base button functionality (from vanilla_button) ===
		"$focus_id|default": "",
		"$focus_override_down|default": "",
		"$focus_override_up|default": "",
		"$focus_override_left|default": "",
		"$focus_override_right|default": "",
		"focus_identifier": "$focus_id",
		"focus_change_down": "$focus_override_down",
		"focus_change_up": "$focus_override_up",
		"focus_change_left": "$focus_override_left",
		"focus_change_right": "$focus_override_right",
		"focus_enabled": true,
		"focus_magnet_enabled": true,
		"focus_wrap_enabled": true,
		"default_focus_precedence": 0,
		"sound_name": "random.click",
		"sound_volume": 1.0,
		"sound_pitch": 1.0,
		"locked_control": "locked",
		"default_control": "default",
		"hover_control": "hover",
		"pressed_control": "pressed",
		"$default_state|default": false,
		"$hover_state|default": false,
		"$pressed_state|default": false,
		"$locked_state|default": false,
		"button_mappings": [
			{
				"from_button_id": "button.menu_select",
				"to_button_id": "button.form_button_click",
				"mapping_type": "pressed"
			},
			{
				"from_button_id": "button.menu_ok",
				"to_button_id": "button.form_button_click",
				"mapping_type": "focused"
			}
		],
		"controls": [
			{
				"default": {
					"type": "panel",
					"size": [
						"100%",
						"100%"
					],
					"anchor_to": "center",
					"anchor_from": "center",
					"controls": [
						{
							"bg": {
								"type": "image",
								"size": ["100%", "100%"],
								"offset": [0, 0],
								"fill": false,
								"anchor_to": "center",
								"anchor_from": "center",
								"texture": "#texture",
								"visible": "#visible",
								"alpha": 1,
								"bindings": [
									{
										/* decode background[440] directly */
										"binding_name": "#form_button_text",
										"binding_type": "collection",
										"binding_collection_name": "form_buttons"
									},
									{
										"binding_type": "view",
										"source_property_name": "('%.440s' * #form_button_text)",
										"target_property_name": "#skip_to_bg"
									},
									{
										"binding_type": "view",
										"source_property_name": "(#form_button_text - #skip_to_bg)",
										"target_property_name": "#rem_at_bg"
									},
									{
										"binding_type": "view",
										"source_property_name": "('%.83s' * #rem_at_bg)",
										"target_property_name": "#raw_bg"
									},
									{
										"binding_type": "view",
										"source_property_name": "(('%.82s' * #raw_bg) - ('%.2s' * #raw_bg) - ';')",
										"target_property_name": "#texture"
									},
									{
										"binding_type": "view",
										"source_property_name": "(not (#texture = ''))",
										"target_property_name": "#visible"
									}
								]
							}
						}
					],
					"$default_state": true
				}
			},
			{
				"hover": {
					"type": "panel",
					"size": [
						"100%",
						"100%"
					],
					"anchor_to": "center",
					"anchor_from": "center",
					"controls": [
						{
							"bg": {
								"type": "image",
								"size": ["100%", "100%"],
								"offset": [0, 0],
								"fill": false,
								"anchor_to": "center",
								"anchor_from": "center",
								"texture": "#texture",
								"visible": "#visible",
								"alpha": 1,
								"bindings": [
									{
										/* decode backgroundHover[1024] directly */
										"binding_name": "#form_button_text",
										"binding_type": "collection",
										"binding_collection_name": "form_buttons"
									},
									{
										"binding_type": "view",
										"source_property_name": "('%.1024s' * #form_button_text)",
										"target_property_name": "#skip_to_bg_hover"
									},
									{
										"binding_type": "view",
										"source_property_name": "(#form_button_text - #skip_to_bg_hover)",
										"target_property_name": "#rem_at_bg_hover"
									},
									{
										"binding_type": "view",
										"source_property_name": "('%.83s' * #rem_at_bg_hover)",
										"target_property_name": "#raw_bg_hover"
									},
									{
										"binding_type": "view",
										"source_property_name": "(('%.82s' * #raw_bg_hover) - ('%.2s' * #raw_bg_hover) - ';')",
										"target_property_name": "#texture"
									},
									{
										"binding_type": "view",
										"source_property_name": "(not (#texture = ''))",
										"target_property_name": "#visible"
									}
								]
							}
						}
					],
					"$hover_state": true
				}
			},
			{
				"pressed": {
					"type": "panel",
					"size": [
						"100%",
						"100%"
					],
					"anchor_to": "center",
					"anchor_from": "center",
					"controls": [
						{
							"bg": {
								"type": "image",
								"size": ["100%", "100%"],
								"offset": [0, 0],
								"fill": false,
								"anchor_to": "center",
								"anchor_from": "center",
								"texture": "#texture",
								"visible": "#visible",
								"alpha": 1,
								"bindings": [
									{
										/* decode backgroundPressed[1107] directly */
										"binding_name": "#form_button_text",
										"binding_type": "collection",
										"binding_collection_name": "form_buttons"
									},
									{
										"binding_type": "view",
										"source_property_name": "('%.1107s' * #form_button_text)",
										"target_property_name": "#skip_to_bg_pressed"
									},
									{
										"binding_type": "view",
										"source_property_name": "(#form_button_text - #skip_to_bg_pressed)",
										"target_property_name": "#rem_at_bg_pressed"
									},
									{
										"binding_type": "view",
										"source_property_name": "('%.83s' * #rem_at_bg_pressed)",
										"target_property_name": "#raw_bg_pressed"
									},
									{
										"binding_type": "view",
										"source_property_name": "(('%.82s' * #raw_bg_pressed) - ('%.2s' * #raw_bg_pressed) - ';')",
										"target_property_name": "#texture"
									},
									{
										"binding_type": "view",
										"source_property_name": "(not (#texture = ''))",
										"target_property_name": "#visible"
									}
								]
							}
						}
					],
					"$pressed_state": true,
					"$button_offset|default": [
						0,
						1
					]
				}
			},
			{
				"locked": {
					"type": "panel",
					"size": [
						"100%",
						"100%"
					],
					"anchor_to": "center",
					"anchor_from": "center",
					"controls": [
						{
							"bg": {
								"type": "image",
								"size": ["100%", "100%"],
								"offset": [0, 0],
								"fill": false,
								"anchor_to": "center",
								"anchor_from": "center",
								"texture": "#texture",
								"visible": "#visible",
								"alpha": 1,
								"bindings": [
									{
										/* decode backgroundLocked[1190] directly */
										"binding_name": "#form_button_text",
										"binding_type": "collection",
										"binding_collection_name": "form_buttons"
									},
									{
										"binding_type": "view",
										"source_property_name": "('%.1190s' * #form_button_text)",
										"target_property_name": "#skip_to_bg_locked"
									},
									{
										"binding_type": "view",
										"source_property_name": "(#form_button_text - #skip_to_bg_locked)",
										"target_property_name": "#rem_at_bg_locked"
									},
									{
										"binding_type": "view",
										"source_property_name": "('%.83s' * #rem_at_bg_locked)",
										"target_property_name": "#raw_bg_locked"
									},
									{
										"binding_type": "view",
										"source_property_name": "(('%.82s' * #raw_bg_locked) - ('%.2s' * #raw_bg_locked) - ';')",
										"target_property_name": "#texture"
									},
									{
										"binding_type": "view",
										"source_property_name": "(not (#texture = ''))",
										"target_property_name": "#visible"
									}
								]
							}
						}
					]
				}
			}
		]
	}
}
