{
	"namespace": "core_ui_components",
	// ─── Item layer ──────────────────────────────────────────────────────────────
	// 9×8 grid bound to form_buttons. beacon.item_renderer needs this native grid
	// context to draw item icons. Each cell uses use_anchored_offset to position
	// itself at its serialized (x, y) — grid slot index is irrelevant.
	"item_renderer": {
		"type": "grid",
		"size": [
			"328px",
			"210px"
		],
		"layer": 90,
		"anchor_from": "top_left",
		"anchor_to": "top_left",
		"collection_name": "form_buttons",
		"grid_dimensions": [
			9,
			8
		],
		"grid_item_template": "core_ui_components.item_cell",
		"bindings": [
			{
				"binding_name": "#form_button_length",
				"binding_name_override": "#maximum_grid_items",
				"binding_condition": "once"
			}
		]
	},
	// ─── Item cell ───────────────────────────────────────────────────────────────
	// 16×16 grid cell (matches ItemRenderer's declared size). Positioned via
	// use_anchored_offset so it ignores its natural grid slot and lands at the
	// absolute (x, y) from the serialized payload — same coordinate origin as
	// content_collection. Non-item entries hidden by type filter.
	"item_cell": {
		"type": "panel",
		"size": [
			16,
			16
		],
		"visible": "#visible",
		"$normalize": 1.0,
		"$aux_id": [
			/* item texture / aux */
			{
				"binding_name": "#form_button_texture",
				"binding_type": "collection",
				"binding_collection_name": "form_buttons"
			},
			{
				"binding_type": "view",
				"source_property_name": "((#form_button_texture - (#form_button_texture % 65536)) / 65536)",
				"target_property_name": "#item_id_aux"
			}
		],
		"bindings": [
			{
				"binding_name": "#form_button_text",
				"binding_type": "collection",
				"binding_collection_name": "form_buttons"
			},
			{
				/* type (field 0) — strip the 9-byte header, read the first 83-byte field */
				"binding_type": "view",
				"source_property_name": "('%.9s' * #form_button_text)",
				"target_property_name": "#protocol_header"
			},
			{
				"binding_type": "view",
				"source_property_name": "(#form_button_text - #protocol_header)",
				"target_property_name": "#rem_after_header"
			},
			{
				"binding_type": "view",
				"source_property_name": "('%.83s' * #rem_after_header)",
				"target_property_name": "#raw_type"
			},
			{
				"binding_type": "view",
				"source_property_name": "(('%.82s' * #raw_type) - ('%.2s' * #raw_type) - ';')",
				"target_property_name": "#type"
			},
			{
				/* visible (field 5, bool) — skip header(9)+type+width+height+x+y = 424 bytes */
				"binding_type": "view",
				"source_property_name": "('%.424s' * #form_button_text)",
				"target_property_name": "#skip_to_visible"
			},
			{
				"binding_type": "view",
				"source_property_name": "(#form_button_text - #skip_to_visible)",
				"target_property_name": "#rem_at_visible"
			},
			{
				"binding_type": "view",
				"source_property_name": "('%.8s' * #rem_at_visible)",
				"target_property_name": "#raw_visible"
			},
			{
				"binding_type": "view",
				"source_property_name": "(('%.7s' * #raw_visible) - ('%.2s' * #raw_visible) - ';')",
				"target_property_name": "#pre_visible"
			},
			{
				"binding_type": "view",
				"source_property_name": "(#pre_visible and (#type = 'item_renderer'))",
				"target_property_name": "#visible"
			}
		],
		"controls": [
			{
				"item@beacon.item_renderer": {
					"size": [
						16,
						16
					],
					"anchor_from": "top_left",
					"anchor_to": "top_left",
					"bindings": "$aux_id"
				}
			}
		]
	}
}