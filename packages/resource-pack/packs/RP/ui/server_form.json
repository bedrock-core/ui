{
	"namespace": "server_form",
	"hud_mirror": {
		"type": "screen",
		"render_only_when_topmost": false,
		"should_steal_mouse": false,
		"is_showing_menu": false,
		"controls": [
			{ "inv@server_form.player_inventory": {} },
			{ "armor@server_form.armor_panel": {} },
			{ "offhand@server_form.offhand_panel": {} }
		]
	},

	"third_party_server_screen": {
		"force_render_below": true,
		"$screen_animations": [
			"@core_ui_animations.screen_enter_animation",
			"@core_ui_animations.screen_exit_animation"
		],
		"modifications": [
			{
				"array_name": "controls",
				"operation": "insert_front",
				"value": [
					{ "hud_mirror@server_form.hud_mirror": {} }
				]
			}
		]
	},
	"long_form": {
		"$protocol_header": "bcuiv0005",
		"modifications": [
			{
				"array_name": "bindings",
				"operation": "insert_back",
				"value": [
					{
						"binding_name": "#title_text"
					},
					{
						"binding_type": "view",
						"source_property_name": "((#title_text - $protocol_header) = #title_text)",
						"target_property_name": "#visible"
					}
				]
			}
		]
	},
	"main_screen_content": {
		"$protocol_header": "bcuiv0005",
		"size": [
			"0px",
			"0px"
		],
		"property_bag": {
			"#size_binding_x": "0px",
			"#size_binding_y": "0px"
		},
		"modifications": [
			{
				"array_name": "controls",
				"operation": "insert_back",
				"value": [
					{
						"core_ui_server_form_factory": {
							"type": "panel",
							"factory": {
								"name": "server_form_factory",
								"control_ids": {
									"long_form": "@core_ui_common.screen_container"
								}
							}
						}
					}
				]
			},
			{
				"array_name": "bindings",
				"operation": "insert_back",
				"value": [
					{
						"binding_name": "#title_text"
					},
					{
						"binding_type": "view",
						"source_property_name": "((((#title_text - $protocol_header) = #title_text) and '0px') or '100%')",
						"target_property_name": "#size_binding_x"
					},
					{
						"binding_type": "view",
						"source_property_name": "((((#title_text - $protocol_header) = #title_text) and '0px') or '100%')",
						"target_property_name": "#size_binding_y"
					}
				]
			}
		]
	},
	"inv_slot@common.empty_panel": {
		"$ci|default": 0,
		"size": [18, 18],
		"controls": [
			{
				"stack": {
					"type": "stack_panel",
					"size": [0, 0],
					"collection_name": "hotbar_items",
					"controls": [
						{
							"binder@common.empty_panel": {
								"collection_index": "$ci",
								"bindings": [
									{
										"binding_type": "collection",
										"binding_name": "#item_id_aux",
										"binding_collection_name": "hotbar_items",
										"binding_condition": "always"
									}
								]
							}
						}
					],
					"bindings": [
						{
							"binding_type": "view",
							"source_control_name": "binder",
							"resolve_sibling_scope": true,
							"source_property_name": "#item_id_aux",
							"target_property_name": "#item_id_aux"
						}
					]
				}
			},
			{
				"renderer": {
					"type": "custom",
					"renderer": "inventory_item_renderer",
					"size": ["100%", "100%"],
					"layer": 2,
					"bindings": [
						{
							"binding_type": "view",
							"source_control_name": "stack",
							"resolve_sibling_scope": true,
							"source_property_name": "#item_id_aux",
							"target_property_name": "#item_id_aux"
						}
					]
				}
			}
		]
	},

