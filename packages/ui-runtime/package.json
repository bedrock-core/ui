{
  "name": "@bedrock-core/ui-runtime",
  "version": "0.8.0",
  "description": "@bedrock-core/ui runtime",
  "keywords": [
    "ui",
    "api",
    "minecraft",
    "bedrock",
    "typescript",
    "framework"
  ],
  "license": "MIT",
  "author": "DrAv0011",
  "contributors": [
    {
      "name": "DrAv0011",
      "email": "contact@drav.dev",
      "url": "https://drav.dev"
    }
  ],
  "repository": "github:bedrock-core/ui",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./jsx-runtime": {
      "types": "./src/jsx/jsx-runtime.ts",
      "import": "./src/jsx/jsx-runtime.ts"
    },
    "./jsx-dev-runtime": {
      "types": "./src/jsx/jsx-dev-runtime.ts",
      "import": "./src/jsx/jsx-dev-runtime.ts"
    }
  },
  "files": [
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "generate:font-metrics": "node ./scripts/generate-font-metrics.mjs",
    "lint": "eslint .",
    "test": "vitest run",
    "coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@minecraft/server": "^2.7.0",
    "@minecraft/server-ui": "^2.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "opentype.js": "^1.3.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "@minecraft/server": "*",
    "@minecraft/server-ui": "*"
  },
  "dependencies": {
    "@bedrock-core/flexbox": "^0.8.0"
  }
}
