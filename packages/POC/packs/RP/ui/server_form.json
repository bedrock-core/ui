{
	"namespace": "server_form",

	// ═══════════════════════════════════════════════════════════════════════════
	// Item Aux POC — final state. Each column demonstrates one verified finding.
	// Full write-up: packages/POC/README.md and ITEM_AUX.md.
	//
	//  Column 1-2 (baseline): items render in every layout context —
	//    natural flow / scroll view / engine factory / factory inside scroll.
	//  Column 3 (FINDING A): #item_id_aux has two representations —
	//    property_bag wants the PACKED aux (raw_id << 16);
	//    bindings want the UNPACKED raw_id (Chest-UI divide).
	//  Column 4 (FINDING B): elevated cumulative layer inside
	//    common.scrolling_panel makes 2D ITEM sprites vanish while 3D BLOCK
	//    meshes survive. This was the bedrock-core factory scroll bug
	//    (item_cell layer 90 + scroll root layer 999 → fixed by lowering both).
	// ═══════════════════════════════════════════════════════════════════════════

	"third_party_server_screen": {
		"modifications": [
			{
				"array_name": "controls",
				"operation": "insert_front",
				"value": [
					{ "proof@server_form.proof_overlay": {} }
				]
			}
		]
	},

