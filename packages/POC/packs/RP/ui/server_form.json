		"type": "stack_panel",
		"orientation": "horizontal",
		"anchor_from": "top_left",
		"anchor_to": "top_left",
		"offset": [4, 4],
		"layer": 10,
		"size": ["100%c", "100%c"],
		"controls": [
			{ "static@server_form.static_column": {} },
			{ "factories@server_form.factories_column": {} },
			{ "f_aux@server_form.finding_aux_column": {} },
			{ "f_layer@server_form.finding_layer_column": {} }
		]
	},

	// ─── Columns 1-2 — baseline: items render in every layout context ─────────

