		"size": [160, "100%c"],
		"controls": [
			{ "factory@server_form.factory_column": {} },
			{ "scroll_factory@server_form.scroll_factory_column": {} }
		]
	},

	"left_column": {
		"type": "stack_panel",
		"orientation": "vertical",
		"size": [160, "100%c"],
		"controls": [
