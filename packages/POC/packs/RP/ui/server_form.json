	},

	"scroll_items": {
		"type": "stack_panel",
		"orientation": "vertical",
		"size": [160, 300],
		"controls": [
			{ "lbl_range@server_form.row_label": { "$lbl": "Block raw_id=1 | Item raw_id=257:" } },
			{ "row_range@server_form.range_row": {} },
			{ "lbl_enchant@server_form.row_label": { "$lbl": "Enchant +32768 (right = glow):" } },
			{ "row_enchant@server_form.enchant_row": {} }
		]
	},

	"factory_scroll@common.scrolling_panel": {
		"size": [160, 80],
		"$show_background": false,
		"$scrolling_content": "server_form.factory_scroll_items"
	},

	"factory_scroll_items": {
		"type": "stack_panel",
		"orientation": "vertical",
		"size": [160, 300],
		"controls": [
			{ "lbl_stones@server_form.row_label": { "$lbl": "2x stone:" } },
			{ "stones@server_form.stone_factory": {} },
			{ "lbl_spears@server_form.row_label": { "$lbl": "2x spear:" } },
			{ "spears@server_form.spear_factory": {} }
		]
	},

	"stone_factory": {
		"type": "stack_panel",
		"orientation": "horizontal",
		"size": ["100%cm", "100%c"],
		"factory": {
			"name": "poc_stone_factory",
			"control_name": "server_form.stone_cell"
		},
		"property_bag": {
			"#count": 2
		},
		"bindings": [
			{
				"binding_type": "view",
				"source_property_name": "#count",
				"target_property_name": "#collection_length"
			}
		]
	},

	"spear_factory": {
		"type": "stack_panel",
		"orientation": "horizontal",
		"size": ["100%cm", "100%c"],
		"factory": {
			"name": "poc_spear_factory",
			"control_name": "server_form.spear_cell"
		},
		"property_bag": {
			"#count": 2
		},
		"bindings": [
			{
				"binding_type": "view",
				"source_property_name": "#count",
				"target_property_name": "#collection_length"
			}
		]
	},

	"stone_cell": {
		"type": "custom",
		"renderer": "inventory_item_renderer",
		"size": [32, 32],
		"property_bag": {
			"#item_id_aux": 65536
		}
	},

	"spear_cell": {
		"type": "custom",
		"renderer": "inventory_item_renderer",
		"size": [32, 32],
		"property_bag": {
			"#item_id_aux": 16842752
		}
	},

	// ─── Column 3 — FINDING A: the two #item_id_aux representations ───────────
	// property_bag JSON literal = PACKED aux int (raw_id << 16, +32768 glint).
	//   Vanilla does the same (beacon netherite 48627712 = 742<<16).
	//   Feeding the raw_id (B) draws nothing: packed 1 = id 0 + data 1 ≈ air.
	// Bindings = UNPACKED raw_id (engine re-packs ×65536, 16.16 fixed-point).
	//   The BP sends the form buttons with numeric icon strings (packed aux);
	//   the cell binds #form_button_texture and applies the Chest-UI divide
	//   ((tex - tex%65536)/65536) → small raw_id → renders. Passing the packed
	//   value through a binding UNDIVIDED renders nothing (it gets re-packed
	//   into garbage). Note: the subtract-modulo strips the enchant bit; a plain
	//   (tex / 65536) would keep it as the .5 fraction.
	"finding_aux_column": {
		"type": "stack_panel",
		"orientation": "vertical",
		"size": [200, "100%c"],
		"controls": [
			{ "lbl@server_form.row_label": { "$lbl": "FINDING A - item_id_aux representations:" } },
			{ "lbl_a1@server_form.row_label": { "$lbl": "property_bag PACKED 65536 -> stone:" } },
			{ "a1@server_form.item_cell": { "$aux": 65536 } },
			{ "lbl_a2@server_form.row_label": { "$lbl": "property_bag raw_id 1 -> blank (wrong repr):" } },
			{ "a2@server_form.item_cell": { "$aux": 1 } },
			{ "lbl_a3@server_form.row_label": { "$lbl": "binding + ChestUI divide -> stone|spear|spear:" } },
			{ "a3@server_form.form_cells_row": {} }
		]
	},

	// ─── Column 4 — FINDING B: elevated layer kills item sprites in scroll ────
	// Minimal pairs, all identical rows except layer:
	//   row 1: no layer        → stone + spears render
	//   row 2: cells layer 90  → stone renders, spears VANISH
	//   K8 box: the scrolling panel itself at layer 999, cells at 0
	//           → stone renders, spears VANISH (the rule is CUMULATIVE layer)
	// Blocks survive because they draw as 3D meshes outside the sprite pass —
	// which is why block-only tests masked this bug. Factory fix: item_cell
	// layer 90→2 AND scroll_screen root layer 999 removed.
	"finding_layer_column": {
		"type": "stack_panel",
		"orientation": "vertical",
		"size": [200, "100%c"],
		"controls": [
			{ "lbl@server_form.row_label": { "$lbl": "FINDING B - layer kills items in scroll:" } },
			{ "lbl_b1@server_form.row_label": { "$lbl": "scroll: row no-layer (all) | row layer90 (stone only):" } },
			{ "b1@server_form.layer_scroll": {} },
			{ "lbl_b2@server_form.row_label": { "$lbl": "scroll BOX layer999, cells 0 -> stone only:" } },
			{ "b2@server_form.layer999_scroll": {} }
		]
	},

	"layer_scroll@common.scrolling_panel": {
		"size": [160, 80],
		"$show_background": false,
		"$scrolling_content": "server_form.layer_scroll_items"
	},

	"layer_scroll_items": {
		"type": "panel",
		"size": [160, 96],
		"anchor_from": "top_left",
		"anchor_to": "top_left",
		"controls": [
			{
				"no_layer_row@server_form.form_cells_row": {
					"anchor_from": "top_left",
					"anchor_to": "top_left",
					"offset": [8, 8]
				}
			},
			{
				"layer90_row@server_form.form_cells_row_l90": {
					"anchor_from": "top_left",
					"anchor_to": "top_left",
					"offset": [8, 48]
				}
			}
		]
	},

	"layer999_scroll@common.scrolling_panel": {
		"size": [160, 80],
		"layer": 999,
		"$show_background": false,
		"$scrolling_content": "server_form.layer999_scroll_items"
	},

	"layer999_scroll_items": {
		"type": "panel",
		"size": [160, 96],
		"anchor_from": "top_left",
		"anchor_to": "top_left",
		"controls": [
			{
				"row@server_form.form_cells_row": {
					"anchor_from": "top_left",
					"anchor_to": "top_left",
					"offset": [8, 8]
				}
			}
		]
	},

	// ─── Shared templates ──────────────────────────────────────────────────────

	"row_label": {
		"type": "label",
		"$lbl|default": "",
		"text": "$lbl",
		"color": [1, 1, 1, 1],
		"font_size": "small",
		"size": ["100%", "default"]
	},

	// Static cell: PACKED aux via property_bag (the vanilla-beacon style).
	"item_cell": {
		"type": "custom",
		"renderer": "inventory_item_renderer",
		"size": [32, 32],
		"$aux|default": 0,
		"property_bag": {
			"#item_id_aux": "$aux"
		}
	},

	"range_row": {
		"type": "stack_panel",
		"orientation": "horizontal",
		"size": ["100%c", 32],
		"controls": [
			{ "stone@server_form.item_cell": { "$aux": 65536 } },
			{ "spear@server_form.item_cell": { "$aux": 16842752 } }
		]
	},

	"enchant_row": {
		"type": "stack_panel",
		"orientation": "horizontal",
		"size": ["100%c", 32],
		"controls": [
			{ "plain@server_form.item_cell": { "$aux": 65536 } },
			{ "glowing@server_form.item_cell": { "$aux": 98304 } }
		]
	},

	// Collection cell: UNPACKED aux via binding (the Chest-UI / factory style).
	// Reads the numeric icon string the BP put on each form button.
	"form_item_cell": {
		"type": "panel",
		"size": [32, 32],
		"controls": [
			{
				"item": {
					"type": "custom",
					"renderer": "inventory_item_renderer",
					"size": [32, 32],
					"anchor_from": "top_left",
					"anchor_to": "top_left",
					"bindings": [
						{
							"binding_name": "#form_button_texture",
							"binding_type": "collection",
							"binding_collection_name": "form_buttons"
						},
						{
							"binding_type": "view",
							"source_property_name": "((#form_button_texture - (#form_button_texture % 65536)) / 65536)",
							"target_property_name": "#item_id_aux"
						}
					]
				}
			}
		]
	},

	// Identical cell at layer 90 — the FINDING B minimal-pair variant.
	"form_item_cell_l90@server_form.form_item_cell": {
		"layer": 90
	},

	"form_cells_row": {
		"type": "stack_panel",
		"orientation": "horizontal",
		"size": ["100%cm", 32],
		"factory": {
			"name": "buttons",
			"control_name": "server_form.form_item_cell"
		},
		"collection_name": "form_buttons",
		"bindings": [
			{
				"binding_name": "#form_button_contents",
				"binding_name_override": "#collection_length"
			}
		]
	},

	"form_cells_row_l90": {
		"type": "stack_panel",
		"orientation": "horizontal",
		"size": ["100%cm", 32],
		"factory": {
			"name": "buttons",
			"control_name": "server_form.form_item_cell_l90"
		},
		"collection_name": "form_buttons",
		"bindings": [
			{
				"binding_name": "#form_button_contents",
				"binding_name_override": "#collection_length"
			}
		]
	}
}
